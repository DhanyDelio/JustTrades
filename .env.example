# ── Binance Spot Testnet (https://testnet.binance.vision) ─────────────────
BINANCE_TESTNET_API_KEY=paste_spot_api_key_disini
BINANCE_TESTNET_API_SECRET=paste_spot_secret_disini

# ── Binance Futures Testnet (https://testnet.binancefuture.com) ───────────
# BERBEDA dari spot — daftar terpisah di testnet.binancefuture.com
BINANCE_FUTURES_TESTNET_API_KEY=paste_futures_api_key_disini
BINANCE_FUTURES_TESTNET_API_SECRET=paste_futures_secret_disini

# ── Supabase (untuk migration dan cloud persistence) ─────────────────────
# Project URL dari Settings → API di dashboard Supabase
SUPABASE_URL=https://<project-id>.supabase.co
# Service role key (bukan anon key) — dari Settings → API → service_role
SUPABASE_SERVICE_KEY=paste_service_role_key_disini

# ── Telegram notifications ─────────────────────────────────────────────────
# Buat bot di @BotFather, ambil chat ID dari @userinfobot
TELEGRAM_BOT_TOKEN=paste_bot_token_disini
TELEGRAM_CHAT_ID=paste_chat_id_disini
